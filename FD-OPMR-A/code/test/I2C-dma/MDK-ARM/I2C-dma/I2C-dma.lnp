"i2c-dma\stm32h7xx_hal_i2c.o"
"i2c-dma\stm32h7xx_hal_i2c_ex.o"
"i2c-dma\stm32h7xx_hal_rcc.o"
"i2c-dma\stm32h7xx_hal_rcc_ex.o"
